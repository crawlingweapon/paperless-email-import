# Example config — copy to config.yaml and fill in your Paperless IDs
# Or use env vars (see README)

paperless:
  base_url: "https://paperless.example.com/api"

onecli:
  gateway: "proxy.example.com:3128"
  agent_name: "hermes"
  ca_cert: "/workspace/onecli-ca.pem"
  # Token comes from ONECLI_TOKEN env var or /workspace/.onecli-agent-token

himalaya:
  account: ""  # default account used if empty

amazon:
  correspondent_id: 0    # Set to your Amazon correspondent PK
  document_type_id: 0     # Set to your Receipt document type PK
  tags: []                # e.g. [28, 26, 27, 30, 29]

custom_fields:
  order_total: 3
  order_number: 4
  order_date: 5
  shipping_cost: 6
  tax_amount: 7
  item_count: 8

archive_folder: "Hermes-Archive-Order"

# --- Tag Heuristics ---
# Uses sentence-transformers to semantically classify order item names into
# categories, adding relevant Paperless tags at import time.
# Model (~80MB) downloads on first use, cached permanently.
tag_heuristics:
  enabled: true
  min_confidence: 0.06       # TF-IDF produces lower scores than embeddings
  auto_create_tags: true     # Auto-create Paperless tags for new categories
  categories:
    Pets:
      color: "#e41a1c"
      tag_id: 0              # 0 = auto-create, or set existing tag ID
    Home Improvement:
      color: "#377eb8"
    Electronics & Tech:
      color: "#4daf4a"
    Kitchen & Dining:
      color: "#984ea3"
    Automotive:
      color: "#ff7f00"
    Health & Beauty:
      color: "#ffff33"
    Office & Stationery:
      color: "#a65628"
    Garden & Outdoor:
      color: "#f781bf"
    Books & Media:
      color: "#999999"
    Clothing & Accessories:
      color: "#e7298a"
    Baby & Kids:
      color: "#66c2a5"
    Sports & Fitness:
      color: "#fc8d62"
    Arts & Crafts:
      color: "#8da0cb"
    Groceries & Food:
      color: "#e78ac3"
